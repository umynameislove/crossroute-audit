{
  "$schema": "https://jsxon-schema.org/draft/2020-12/schema",
  "title": "CrossRoute-Audit causal effect artifact",
  "description": "Per-sample layer-wise causal-effect output. Raw tensors are never stored.",
  "type": "object",
  "additionalProperties": false,
  "required": ["sample_id", "target_answer", "C_by_layer", "stability", "settings"],
  "properties": {
    "sample_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_\\-]+$"
    },
    "target_answer": {
      "type": "string",
      "minLength": 1
    },
    "C_by_layer": {
      "$ref": "#/$defs/group_layer_effects"
    },
    "stability": {
      "$ref": "#/$defs/group_layer_stability"
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "layer_count", "groups", "stability_layer", "stability_repeats"],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "layer_count": {
          "type": "integer",
          "minimum": 1
        },
        "groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stability_layer": {
          "type": "integer",
          "minimum": 0
        },
        "stability_repeats": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "$defs": {
    "group_layer_effects": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_\\-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "minProperties": 1,
        "propertyNames": {
          "pattern": "^[0-9]+$"
        },
        "additionalProperties": {
          "type": "number"
        }
      }
    },
    "group_layer_stability": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_\\-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "minProperties": 1,
        "propertyNames": {
          "pattern": "^[0-9]+$"
        },
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mean", "std", "max_abs_dev"],
          "properties": {
            "mean": {
              "type": "number"
            },
            "std": {
              "type": "number",
              "minimum": 0
            },
            "max_abs_dev": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
