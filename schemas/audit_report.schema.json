{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CrossRoute-Audit per-sample audit report",
  "description": "Final GĐ4 per-sample audit report. Raw tensors are never stored.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sample_id",
    "target_answer",
    "rank_alignment",
    "secondary",
    "control_status",
    "diagnosis",
    "settings"
  ],
  "properties": {
    "sample_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_\\-]+$"
    },
    "target_answer": {
      "type": "string",
      "minLength": 1
    },
    "rank_alignment": {
      "type": "object",
      "description": "Primary RankAlignment metric by group or layer."
    },
    "secondary": {
      "type": "object",
      "description": "Secondary diagnostics such as attribution-flow gap and flow retention."
    },
    "control_status": {
      "type": ["object", "null"],
      "description": "Control-gate results, usually the controls object from control_status.json."
    },
    "diagnosis": {
      "type": "object",
      "additionalProperties": true,
      "required": ["diagnosis", "confidence", "reasons"],
      "properties": {
        "diagnosis": {
          "type": "string",
          "enum": [
            "false_attribution_persistence",
            "modality_drop",
            "route_break",
            "language_prior",
            "redundancy",
            "no_flag",
            "low_confidence"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "low"]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "description": "Audit/report settings used to generate this artifact."
    }
  }
}
